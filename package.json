{
  "name": "altax-backend",
  "version": "0.1.0",
  "description": "AL TAX SERVICE - Phase 0 backend foundation (auth, db, migration skeleton)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/assets && cp -r src/assets/. dist/assets/",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "migrate:schema": "psql \"$DATABASE_URL\" -f sql/001_init_schema.sql",
    "migrate:sheets": "ts-node src/migration/sheetsToPostgres.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^13.4.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "resend": "^6.17.2",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
