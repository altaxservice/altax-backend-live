# Phase 0 environment template
DATABASE_URL=postgres://altax_app:changeme@localhost:5432/altax
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h
PORT=4000

# Base URL used to build portal invite links returned by POST /users (see
# src/modules/users/users.routes.ts and src/common/portalUserProvisioning.ts). Falls
# back to http://localhost:5173 if unset — set this to the real frontend origin once
# deployed so invite links/emails point somewhere the recipient can actually reach.
FRONTEND_BASE_URL=

# Master key for the Secure Vault and encrypted Payment Method fields
# (src/common/encryption.ts). Must be a base64-encoded 32-byte (256-bit) key.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key permanently and unrecoverably locks every encrypted value in the
# database — back it up somewhere durable outside this repo (a password manager,
# a secrets vault), never commit it, and never rotate it without a re-encryption plan.
VAULT_MASTER_KEY=

# Used only by the one-time/ incremental Sheets -> Postgres migration job
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service-account.json
SOURCE_SPREADSHEET_ID=replace-with-the-existing-AL-TAX-spreadsheet-id

# Email sending (src/common/notifications.ts) — get an API key at https://resend.com.
# Sending is skipped with a clear "not configured" error until this is set; nothing
# breaks by leaving it blank.
RESEND_API_KEY=
RESEND_FROM_EMAIL=AL Tax Service <onboarding@resend.dev>

# SMS/WhatsApp sending (src/common/notifications.ts) — get these from a Twilio console
# (https://twilio.com). TWILIO_FROM_NUMBER is a Twilio phone number you've purchased.
# TWILIO_WHATSAPP_FROM additionally requires Twilio's WhatsApp Business API, which
# needs Meta business verification — a longer setup than SMS or email. Each channel
# is independently optional; missing ones just show "not configured" in the send UI.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
